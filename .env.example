# PostgreSQL
POSTGRES_DB=beauty_services
POSTGRES_USER=beauty_services
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
# Use localhost when running the backend on the host machine against the dockerized database.
# If the backend runs inside Docker Compose, use: postgresql://beauty_services:changeme@postgres:5432/beauty_services
DATABASE_URL=postgresql://beauty_services:changeme@localhost:5432/beauty_services

# Backend
PORT=3001
NODE_ENV=development

# Google Places API (collection script only)
GOOGLE_PLACES_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
